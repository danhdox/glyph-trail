{
  "name": "@glyph-trail/core",
  "version": "0.1.0",
  "description": "Framework-agnostic Canvas 2D renderer for interactive pixel-particle / glyph dither effects.",
  "license": "MIT",
  "author": "Andrewdddobusiness",
  "homepage": "https://github.com/Andrewdddobusiness/glyph-trail#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Andrewdddobusiness/glyph-trail.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Andrewdddobusiness/glyph-trail/issues"
  },
  "keywords": [
    "canvas",
    "pixelation",
    "particles",
    "dither",
    "glyph",
    "creative-coding",
    "cursor",
    "interactive",
    "image-effect",
    "effect"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
