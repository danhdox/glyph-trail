{
  "name": "@glyph-trail/react",
  "version": "0.1.0",
  "description": "React component wrapper for Glyph Trail.",
  "license": "MIT",
  "author": "Andrewdddobusiness",
  "homepage": "https://github.com/Andrewdddobusiness/glyph-trail#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Andrewdddobusiness/glyph-trail.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/Andrewdddobusiness/glyph-trail/issues"
  },
  "keywords": [
    "canvas",
    "pixelation",
    "particles",
    "dither",
    "glyph",
    "react",
    "creative-coding",
    "interactive",
    "effect"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "pnpm --filter @glyph-trail/core build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @glyph-trail/core build && tsc -p tsconfig.json --noEmit",
    "lint": "pnpm --filter @glyph-trail/core build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@glyph-trail/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.2.0 || >=19.0.0",
    "react-dom": ">=18.2.0 || >=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "typescript": "^5.7.2"
  }
}
